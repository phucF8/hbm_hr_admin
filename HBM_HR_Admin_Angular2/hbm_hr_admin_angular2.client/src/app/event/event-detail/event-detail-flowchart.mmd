    X3 -- "Co" --> X5["Lay imageUrl tu response"]

    X1 --> Y{"isEditMode && data?"}
    X5 --> Y

    Y -- "Khong" --> Z["createEvent(formValue, imageUrl)"]
    Y -- "Co" --> AA["updateEvent(formValue, imageUrl)"]

    Z --> Z1["generateHtmlContent(imageUrl)"]
    Z1 --> Z2["eventService.createEvent"]
    Z2 --> Z3{"API SUCCESS?"}
    Z3 -- "Co" --> Z4["isSubmitting=false + Swal success + close(true)"]
    Z3 -- "Khong" --> Z5["isSubmitting=false + Swal error"]

    AA --> AA1["generateHtmlContent(imageUrl)"]
    AA1 --> AA2["eventService.updateEvent"]
    AA2 --> AA3{"API SUCCESS?"}
    AA3 -- "Co" --> AA4["isSubmitting=false + Swal success + close(true)"]
    AA3 -- "Khong" --> AA5["isSubmitting=false + Swal error"]

    R --> AB["Nguoi dung bam Huy"]
