    K --> L{"File hop le image/*?"}
    L -- "Khong" --> L1["Swal loi va return"]
    L -- "Co" --> M{"File <= 5MB?"}
    M -- "Khong" --> M1["Swal loi va return"]
    M -- "Co" --> N["Set selectedImageFile/name"]
    N --> O["FileReader doc anh"]
    O --> P["set previewUrl"]
    P --> Q["updateIframeContent"]

